{
  "name": "maitre-d",
  "version": "0.1.0",
  "description": "The open-source, AI-powered restaurant reservation agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "maitre-d": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "restaurant",
    "reservation",
    "resy",
    "opentable",
    "tock",
    "booking",
    "cli",
    "ai"
  ],
  "author": "Aarav Jaichand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaravjaichand/maitre-d.git"
  },
  "bugs": {
    "url": "https://github.com/aaravjaichand/maitre-d/issues"
  },
  "homepage": "https://github.com/aaravjaichand/maitre-d#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ]
}
