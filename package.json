{
  "name": "maitre-d",
  "version": "0.1.0",
  "description": "The open-source, AI-powered restaurant reservation agent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "maitre-d": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "restaurant",
    "reservation",
    "resy",
    "opentable",
    "booking",
    "cli",
    "ai"
  ],
  "author": "Aarav Jaichand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaravjaichand/maitre-d.git"
  },
  "bugs": {
    "url": "https://github.com/aaravjaichand/maitre-d/issues"
  },
  "homepage": "https://github.com/aaravjaichand/maitre-d#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.4"
  }
}
